      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_GRAFANACLOUD_PROMETHEUS}" },
          "expr": "sum by (device_type) (qoe_active_sessions)",
          "legendFormat": "{{device_type}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_GRAFANACLOUD_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": {} },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 13 },
      "id": 12,
      "options": { "legend": { "displayMode": "table", "placement": "right" }, "pieType": "donut" },
      "title": "Sessions by Network Type",
      "type": "piechart",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_GRAFANACLOUD_PROMETHEUS}" },
          "expr": "sum by (network_type) (qoe_active_sessions)",
          "legendFormat": "{{network_type}}",
          "refId": "A"
        }
      ]
