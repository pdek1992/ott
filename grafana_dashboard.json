        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 34 },
      "id": 32,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "title": "Avg Bitrate vs Client Bandwidth",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_GRAFANACLOUD_PROMETHEUS}" },
          "expr": "avg(qoe_avg_bitrate_kbps)",
          "legendFormat": "Avg Bitrate kbps",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_GRAFANACLOUD_PROMETHEUS}" },
          "expr": "avg(qoe_avg_bandwidth_kbps)",
