{
  "__inputs": [
    {
      "name": "DS_GRAFANACLOUD_PROMETHEUS",
      "label": "Grafana Cloud Prometheus",
      "description": "Grafana Cloud Prometheus datasource (configure this to your instance)",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "gauge", "name": "Gauge", "version": "" },
    { "type": "panel", "id": "piechart", "name": "Pie chart", "version": "" },
    { "type": "panel", "id": "table", "name": "Table", "version": "" }
  ],
  "annotations": { "list": [] },
  "description": "VigilSiddhi OTT – Client QoE + Cloudflare CDN observability dashboard",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "📺 Client QoE Metrics",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_GRAFANACLOUD_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 2 },
              { "color": "red", "value": 3 }
            ]
          },
          "unit": "s",
          "mappings": []
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "Avg Startup Time",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_GRAFANACLOUD_PROMETHEUS}" },
          "expr": "avg(qoe_startup_time_seconds{region=\"IN\"})",
          "legendFormat": "Startup Time",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_GRAFANACLOUD_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.015 },
              { "color": "red", "value": 0.03 }
            ]
          },
          "unit": "percentunit",
          "min": 0,
          "max": 0.2
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "title": "Avg Rebuffer Ratio",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_GRAFANACLOUD_PROMETHEUS}" },
          "expr": "avg(qoe_rebuffer_ratio{region=\"IN\"})",
          "legendFormat": "Rebuffer Ratio",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_GRAFANACLOUD_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 800 },
              { "color": "green", "value": 1500 }
            ]
          },
          "unit": "none",
          "custom": { "displayMode": "auto" }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "id": 3,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "title": "Avg Bitrate (kbps)",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_GRAFANACLOUD_PROMETHEUS}" },
          "expr": "avg(qoe_avg_bitrate_kbps{region=\"IN\"})",
          "legendFormat": "Avg Bitrate",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_GRAFANACLOUD_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.01 }
            ]
          },
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "id": 4,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false }
      },
      "title": "Error Rate",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_GRAFANACLOUD_PROMETHEUS}" },
          "expr": "avg(qoe_error_rate{region=\"IN\"})",
          "legendFormat": "Error Rate",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_GRAFANACLOUD_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "id": 5,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false }
      },
      "title": "Active Sessions",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_GRAFANACLOUD_PROMETHEUS}" },
          "expr": "sum(qoe_active_sessions)",
          "legendFormat": "Active Sessions",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_GRAFANACLOUD_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 15, "gradientMode": "opacity", "spanNulls": true }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Startup Time (s)" }, "properties": [{ "id": "unit", "value": "s" }, { "id": "color", "value": { "fixedColor": "#27d7ff", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Rebuffer %" }, "properties": [{ "id": "unit", "value": "percent" }, { "id": "color", "value": { "fixedColor": "#ffb347", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Bitrate kbps ÷ 10" }, "properties": [{ "id": "color", "value": { "fixedColor": "#7dffbf", "mode": "fixed" } }] }
        ]
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 5 },
      "id": 10,
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "lastNotNull"] },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "title": "QoE Metrics — Time Series",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_GRAFANACLOUD_PROMETHEUS}" },
          "expr": "avg(qoe_startup_time_seconds{region=\"IN\"})",
          "legendFormat": "Startup Time (s)",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_GRAFANACLOUD_PROMETHEUS}" },
          "expr": "avg(qoe_rebuffer_ratio{region=\"IN\"}) * 100",
          "legendFormat": "Rebuffer %",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_GRAFANACLOUD_PROMETHEUS}" },
          "expr": "avg(qoe_avg_bitrate_kbps{region=\"IN\"}) / 10",
          "legendFormat": "Bitrate kbps ÷ 10",
          "refId": "C"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_GRAFANACLOUD_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": {} },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 13 },
