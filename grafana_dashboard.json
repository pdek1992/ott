      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_GRAFANACLOUD_PROMETHEUS}" },
          "expr": "cdn_cache_hit_ratio * 100",
          "legendFormat": "Cache Hit %",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_GRAFANACLOUD_PROMETHEUS}" },
          "expr": "cdn_error_rate * 100",
