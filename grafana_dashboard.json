  "refresh": "30s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["ott", "qoe", "cdn", "cloudflare", "grafana-cloud"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Region",
        "multi": false,
        "name": "region",
        "options": [],
        "query": {
          "query": "label_values(qoe_startup_time_seconds, region)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "VigilSiddhi OTT Observability",
  "uid": "vigil-ott-obs-v1",
  "version": 1
}
