{
  "__inputs": [
    {
      "name": "DS_GRAFANACLOUD_PROMETHEUS",
      "label": "Grafana Cloud Prometheus",
      "description": "Grafana Cloud Prometheus datasource (configure this to your instance)",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.0.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    },
    {
      "type": "panel",
      "id": "gauge",
      "name": "Gauge",
      "version": ""
    },
    {
      "type": "panel",
      "id": "piechart",
      "name": "Pie chart",
      "version": ""
    },
    {
      "type": "panel",
      "id": "table",
      "name": "Table",
      "version": ""
    }
  ],
  "annotations": {
    "list": []
  },
  "description": "VigilSiddhi OTT – Client QoE + Cloudflare CDN observability dashboard",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": null,
      "gridPos": {
        "h": 4,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "mode": "markdown",
      "options": {
        "content": "<div style=\"display: flex; align-items: center; justify-content: center; height: 100%;\">\n  <img src=\"public/img/logo.png\" style=\"height: 60px; margin-right: 20px;\">\n  <h1 style=\"font-size: 32px; color: #00B4D8; margin: 0;\">VigilSiddhi OTT</h1>\n  <span style=\"margin-left: 20px; font-size: 14px; opacity: 0.7;\">Live Observability Dashboard</span>\n</div>"
      },
      "title": "",
      "type": "text"
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 4
      },
      "id": 2,
      "title": "📊 Global CDN Performance KPIs",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_GRAFANACLOUD_PROMETHEUS}"
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 5
      },
      "id": 3,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center"
      },
      "title": "Total Requests (24h)",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(cdn_requests)",
          "legendFormat": "Requests",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_GRAFANACLOUD_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 0.7
              }
            ]
          }
        }
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 4,
        "y": 5
      },
      "id": 4,
      "options": {
        "colorMode": "background",
        "justifyMode": "center"
      },
      "title": "Cache Hit Ratio",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(cdn_cached_requests) / sum(cdn_requests)",
          "legendFormat": "CHR",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_GRAFANACLOUD_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "decbytes"
        }
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 8,
        "y": 5
      },
      "id": 5,
      "options": {
        "colorMode": "value",
        "justifyMode": "center"
      },
      "title": "Bandwidth (Egress)",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(cdn_bytes)",
          "legendFormat": "Bandwidth",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_GRAFANACLOUD_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 0.1
              }
            ]
          }
        }
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 12,
        "y": 5
      },
      "id": 6,
      "options": {
        "colorMode": "background",
        "justifyMode": "center"
      },
      "title": "Bandwidth Saved",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(cdn_cached_bytes) / sum(cdn_bytes)",
          "legendFormat": "Saved",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_GRAFANACLOUD_PROMETHEUS}"
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 16,
        "y": 5
      },
      "id": 7,
      "options": {
        "colorMode": "value",
        "justifyMode": "center"
      },
      "title": "Blocked Threats",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(cdn_threats)",
          "legendFormat": "Threats",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_GRAFANACLOUD_PROMETHEUS}"
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 20,
        "y": 5
      },
      "id": 8,
      "options": {
        "colorMode": "value",
        "justifyMode": "center"
      },
      "title": "Unique Pageviews",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(cdn_pageviews)",
          "legendFormat": "Pageviews",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 9
      },
      "id": 10,
      "title": "🌐 CDN Traffic Breakdowns",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_GRAFANACLOUD_PROMETHEUS}"
      },
      "gridPos": {
        "h": 9,
        "w": 8,
        "x": 0,
        "y": 10
      },
      "id": 11,
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "pieType": "donut"
      },
      "title": "🌍 Requests by Country",
      "type": "piechart",
      "targets": [
        {
          "expr": "sum by (country) (cdn_requests_by_country)",
          "legendFormat": "{{country}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_GRAFANACLOUD_PROMETHEUS}"
      },
      "gridPos": {
        "h": 9,
        "w": 8,
        "x": 8,
        "y": 10
      },
      "id": 12,
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "pieType": "donut"
      },
      "title": "🏥 Edge Status Codes",
      "type": "piechart",
      "targets": [
        {
          "expr": "sum by (status) (cdn_requests_by_status)",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_GRAFANACLOUD_PROMETHEUS}"
      },
      "gridPos": {
        "h": 9,
        "w": 8,
        "x": 16,
        "y": 10
      },
      "id": 13,
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "pieType": "donut"
      },
      "title": "📱 Device/Browser Analytics",
      "type": "piechart",
      "targets": [
        {
          "expr": "sum by (browser) (cdn_requests_by_browser)",
          "legendFormat": "{{browser}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_GRAFANACLOUD_PROMETHEUS}"
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 19
      },
      "id": 14,
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "pieType": "donut"
      },
      "title": "⚡ Protocol Version (HTTP/x)",
      "type": "piechart",
      "targets": [
        {
          "expr": "sum by (version) (cdn_requests_by_http_version)",
          "legendFormat": "{{version}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_GRAFANACLOUD_PROMETHEUS}"
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 19
      },
      "id": 15,
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "pieType": "donut"
      },
      "title": "📦 Asset Content Types",
      "type": "piechart",
      "targets": [
        {
          "expr": "sum by (type) (cdn_requests_by_content_type)",
          "legendFormat": "{{type}}",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 28
      },
      "id": 20,
      "title": "📺 Player QoE & Performance",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_GRAFANACLOUD_PROMETHEUS}"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 29
      },
      "id": 21,
      "title": "Startup & Buffering Trends",
      "type": "timeseries",
      "targets": [
        {
          "expr": "avg(qoe_startup_time_seconds)",
          "legendFormat": "Startup (s)",
          "refId": "A"
        },
        {
          "expr": "avg(qoe_rebuffer_ratio) * 100",
          "legendFormat": "Rebuffer %",
          "refId": "B"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 37
      },
      "id": 30,
      "title": "🌍 World Map",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_GRAFANACLOUD_PROMETHEUS}"
      },
      "gridPos": {
        "h": 12,
        "w": 24,
        "x": 0,
        "y": 38
      },
      "id": 31,
      "options": {
        "basemap": {
          "config": {},
          "name": "Layer 0",
          "type": "default"
        },
        "controls": {
          "showAttribution": true,
          "showDebug": false,
          "showZoom": true
        },
        "layers": [
          {
            "config": {
              "showLegend": true,
              "style": {
                "color": {
                  "fixed": "dark-blue"
                },
                "opacity": 0.4,
                "rotation": {
                  "fixed": 0
                },
                "size": {
                  "field": "value",
                  "fixed": 5,
                  "max": 15,
                  "min": 2
                },
                "symbol": {
                  "fixed": "circle"
                },
                "textConfig": {
                  "fontSize": 12,
                  "textAlign": "center",
                  "textBaseline": "middle"
                }
              }
            },
            "location": {
              "id": "lookup",
              "options": {
                "mapping": {
                  "text": "country"
                }
              }
            },
            "name": "Requests by Country",
            "tooltip": true,
            "type": "markers"
          }
        ],
        "view": {
          "id": "world",
          "lat": 20,
          "lon": 78,
          "zoom": 4
        }
      },
      "title": "Request Origin Map",
      "type": "geomap",
      "targets": [
        {
          "expr": "sum by (country) (cdn_requests_by_country)",
          "format": "table",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": [
    "ott",
    "qoe",
    "cdn",
    "cloudflare",
    "grafana-cloud"
  ],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Region",
        "multi": false,
        "name": "region",
        "options": [],
        "query": {
          "query": "label_values(qoe_startup_time_seconds, region)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "browser",
  "title": "VigilSiddhi OTT Observability",
  "uid": "vigil-ott-obs-v1",
  "version": 2
}