          "datasource": { "type": "prometheus", "uid": "${DS_GRAFANACLOUD_PROMETHEUS}" },
          "expr": "avg(qoe_startup_time_seconds) > 3",
          "legendFormat": "startup_time_breach",
          "refId": "A",
          "instant": true
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_GRAFANACLOUD_PROMETHEUS}" },
          "expr": "avg(qoe_rebuffer_ratio) > 0.03",
          "legendFormat": "rebuffer_ratio_breach",
          "refId": "B",
          "instant": true
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_GRAFANACLOUD_PROMETHEUS}" },
          "expr": "cdn_cache_hit_ratio < 0.7",
          "legendFormat": "cache_hit_low",
          "refId": "C",
          "instant": true
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_GRAFANACLOUD_PROMETHEUS}" },
          "expr": "cdn_error_rate > 0.02",
          "legendFormat": "cdn_error_high",
          "refId": "D",
          "instant": true
        }
      ]
    }
